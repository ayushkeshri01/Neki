# ===========================================
# Neki Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values

# Database (PostgreSQL)
# Example: postgresql://user:password@localhost:5432/dogood
# In production/serverless, use a pooled URL for DATABASE_URL.
# If your provider gives a direct connection URL, put it in DIRECT_URL for migrations.
DATABASE_URL="postgresql://dogood:dogood123@localhost:5432/dogood"
DIRECT_URL=""

# NextAuth Configuration
# Generate a secret with: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME_generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# AWS S3 for Image Storage (Required for uploads)
# Get these from AWS IAM
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET="dogood-uploads"

# SMTP Configuration (Required for OTP)
# For Gmail, use an App Password
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false" # Use false for STARTTLS (Port 587)
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Site URL (used by metadata, links, and sitemap generation)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional admin bootstrap values for npm run admin:create
ADMIN_EMAIL=""
ADMIN_NAME=""
ADMIN_PASSWORD=""
