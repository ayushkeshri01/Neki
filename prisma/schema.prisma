generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String     @id @default(cuid())
  email                   String     @unique
  password                String?
  name                    String?
  image                   String?
  bio                     String?
  role                    Role       @default(MEMBER)
  status                  UserStatus @default(ACTIVE)
  statusReason            String?
  statusChangedAt         DateTime?
  points                  Int        @default(0)
  badges                  String[]   @default([])
  banned                  Boolean    @default(false)
  banReason               String?
  adminMessage            String?
  lastLoginAt             DateTime?
  privacyPolicyAcceptedAt DateTime?
  privacyPolicyVersion    String?
  emailVerified           DateTime?
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt

  // Auth Relations
  accounts            Account[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]

  // App Relations
  memberships      CommunityMember[]
  posts            Post[]
  likes            Like[]
  reports          Report[]
  notices          UserNotice[]
  adminCommunities Community[]       @relation("CommunityAdmin")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  ADMIN
  MEMBER
}

enum UserStatus {
  ACTIVE
  BLACKLISTED
  REMOVED
}

model Community {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  adminId String
  admin   User              @relation("CommunityAdmin", fields: [adminId], references: [id], onDelete: Restrict)
  members CommunityMember[]
  posts   CommunityPost[]
}

model CommunityMember {
  id          String   @id @default(cuid())
  userId      String
  communityId String
  joinedAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([userId, communityId])
}

model Post {
  id               String     @id @default(cuid())
  content          String
  images           String[]   @default([])
  points           Int        @default(50)
  status           PostStatus @default(VISIBLE)
  moderationReason String?
  moderatedAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  // Relations
  authorId    String
  author      User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  communities CommunityPost[]
  likes       Like[]
  reports     Report[]

  @@index([authorId])
  @@index([status])
}

enum PostStatus {
  VISIBLE
  HIDDEN
  REMOVED
}

model CommunityPost {
  id          String   @id @default(cuid())
  postId      String
  communityId String
  createdAt   DateTime @default(now())

  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([postId, communityId])
}

model Like {
  id        String       @id @default(cuid())
  userId    String
  postId    String
  type      ReactionType @default(LIKE)
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId, type])
  @@index([userId])
}

enum ReactionType {
  LIKE
  CELEBRATE
  LOVE
  INSIGHTFUL
  SUPPORT
}

model Report {
  id         String       @id @default(cuid())
  userId     String
  postId     String
  reason     String
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  resolvedAt DateTime?
  resolvedBy String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([postId])
  @@unique([userId, postId])
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

model AppSettings {
  id                   String   @id @default("default")
  allowedDomains       String[] @default([])
  privacyPolicyVersion String   @default("v1")
  autoLogoutDays       Int?
  updatedAt            DateTime @updatedAt
}

enum RegistrationTokenStatus {
  ACTIVE
  CONSUMED
  REVOKED
}

enum ModerationActionType {
  SYSTEM_AUTO_HIDE_POST
  ADMIN_HIDE_POST
  ADMIN_REMOVE_POST
  ADMIN_RESTORE_POST
  ADMIN_BLACKLIST_USER
  ADMIN_REMOVE_USER
  ADMIN_REINSTATE_USER
}

enum UserNoticeType {
  POST_HIDDEN
  POST_REMOVED
  POST_RESTORED
  POST_REPORTED
  ACCOUNT_BLACKLISTED
  ACCOUNT_REMOVED
  ACCOUNT_REINSTATED
  ADMIN_MESSAGE
  ACHIEVEMENT_FIRST_POST
}

model RegistrationToken {
  id                 String                  @id @default(cuid())
  email              String
  tokenHash          String                  @unique
  status             RegistrationTokenStatus @default(ACTIVE)
  policyVersion      String
  issuedAt           DateTime                @default(now())
  expiresAt          DateTime
  acceptedAt         DateTime?
  consumedAt         DateTime?
  revokedAt          DateTime?
  revokedReason      String?
  createdIp          String?
  createdUserAgent   String?
  finalizedIp        String?
  finalizedUserAgent String?

  @@index([email, status])
  @@index([expiresAt])
}

model ModerationAudit {
  id             String               @id @default(cuid())
  actionType     ModerationActionType
  actorUserId    String
  targetUserId   String?
  targetPostId   String?
  reason         String?
  metadata       Json?
  idempotencyKey String?
  createdAt      DateTime             @default(now())

  @@unique([actorUserId, idempotencyKey])
  @@index([targetUserId, createdAt])
  @@index([targetPostId, createdAt])
}

model UserNotice {
  id                 String         @id @default(cuid())
  userId             String
  noticeType         UserNoticeType
  title              String
  body               String
  payload            Json?
  auditId            String?
  createdAt          DateTime       @default(now())
  acknowledgedAt     DateTime?
  visibleFromLoginAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, auditId, noticeType])
  @@index([userId, acknowledgedAt])
  @@index([createdAt])
}

model OTP {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([email, code])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  used      Boolean   @default(false)
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
